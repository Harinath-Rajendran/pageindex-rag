# Copy this file to `.env` and fill in real values. Never commit .env.

# ── LLM backend selection ─────────────────────────────────────────────────
# "claude" (via LiteLLM proxy) or "ollama" (local)
LLM_MODE=claude

# ── Claude / LiteLLM settings (when LLM_MODE=claude) ──────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
LITELLM_BASE_URL=http://localhost:4000
LITELLM_API_KEY=change-me-to-a-strong-random-value
QUERY_MODEL=claude-sonnet
INDEX_MODEL=claude-sonnet

# ── Ollama settings (when LLM_MODE=ollama) ────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma3:4b

# ── PageIndex tree builder (optional, for PDF structure) ──────────────────
PAGEINDEX_DIR=/PageIndex

# ── Web server ────────────────────────────────────────────────────────────
PORT=5000

# ── Security (production) ─────────────────────────────────────────────────
# Set to 1 when serving behind HTTPS. Sessions will refuse to work on plain HTTP.
COOKIE_SECURE=0

# Comma-separated list of allowed CORS origins. Leave blank for same-origin only.
# CORS_ORIGINS=https://chat.example.com
